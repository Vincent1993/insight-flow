{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@insight-flow/protocol": [
        "packages/protocol/src/index.ts"
      ],
      "@insight-flow/core": [
        "packages/core/src/index.ts"
      ],
      "@insight-flow/core/*": [
        "packages/core/src/*"
      ],
      "@insight-flow/llm-connectors": [
        "packages/llm-connectors/src/index.ts"
      ],
      "@insight-flow/llm-connectors/*": [
        "packages/llm-connectors/src/*"
      ],
      "@insight-flow/data-cleaner": [
        "packages/data-cleaner/src/index.ts"
      ],
      "@insight-flow/data-cleaner/*": [
        "packages/data-cleaner/src/*"
      ],
      "@insight-flow/compute-engine": [
        "packages/compute-engine/src/index.ts"
      ],
      "@insight-flow/compute-engine/*": [
        "packages/compute-engine/src/*"
      ]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
